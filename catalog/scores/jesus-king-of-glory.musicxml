    <work-title>Jesus, King of Glory</work-title>
  </work>
  <identification>
    <creator type="composer">Words: W. Hope Davison, 1880.
Music: 'St. Alban' Franz Joseph Haydn, 1774.  Setting: John Bacchus Dykes, 1868.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2005 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
