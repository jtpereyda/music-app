bar

//15
1: 4ac;; 8; c+e; be; ae;
2: 4ea-;; 8; aa-; gb-; ac;

	VS "gar-ments spot-less? Are they";
bar

//16
1: 4fd;;; 8;;
2: 4ad;;; 8;;

	VS "white as snow? Are you";
bar

//17
1: 4ec; 8;; 4ae; 8gd;;
2: 4ae; 8;; 4c+e; 8be;;

	VS "washed in the blood of the";
bar

//18 
