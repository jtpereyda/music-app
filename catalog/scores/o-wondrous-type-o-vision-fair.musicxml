<score-partwise>
  <work>
    <work-title>O Wondrous Type, O Vision Fair</work-title>
  </work>
  <identification>
    <creator type="composer">Words: From the "Sarum Breviary", 1495.  Translated by John Mason Neale, 1851.
Music: 'Deo Gracias' or 'Agincourt' traditional English, circa 1415.  Setting: Charles Winfred Douglas, 1918, alt.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2011 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: "A Hymnal" (Episcopal), 1918 Hymn 439, alt by BJD 21 Mar 2011.  Translation found in Hymns Ancient &amp; Modern, 1861.</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6.O Father, with th'Eternal Son,
and Holy Spirit, ever One,
Vouchsafe to bring us by Thy grace
to see Thy glory face to face.</miscellaneous-field>
    </miscellaneous>
  </identification>
