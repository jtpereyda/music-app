<score-partwise>
  <work>
    <work-title>Angels From the Realms of Glory</work-title>
  </work>
  <identification>
    <creator type="composer">Words: James Montgomery, 1816.
Music: 'Regent Square' Henry Smart, 1867.  Setting: "Psalms and Hymns for Divine Worship", 1867.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2007 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: "Psalms and Hymns for Divine Worship", 1867 Hymn 58.</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6.Though an Infant now we view Him,
He shall fill His Father's throne,
Gather all the nations to Him;
Every knee shall then bow down:

7.All creation, join in praising
God, the Father, Spirit, Son,
Evermore your voices raising
To th'eternal Three in One.</miscellaneous-field>
    </miscellaneous>
  </identification>
