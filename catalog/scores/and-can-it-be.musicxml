<score-partwise>
  <work>
    <work-title>And Can It Be</work-title>
  </work>
  <identification>
    <creator type="composer">Words: Charles Wesley, 1738.
Music: 'Fillmore' Jeremiah Ingalls (1764-1828).  Setting: "The Methodist Hymnal", 1905.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2010 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
