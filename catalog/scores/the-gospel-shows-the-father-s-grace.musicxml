<score-partwise>
  <work>
    <work-title>The Gospel Shows The Father's Grace</work-title>
  </work>
  <identification>
    <creator type="composer">Words: Matthias Loy, 1863.
Music: 'Herr Jesu Christ, Dict Zu Uns Wend' from Cantionale Germanicum, Dresden, 1628.
Setting: "Mehrstimmiges ChoralBuch", 1906, alt.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2008 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: "Mehrstimmiges ChoralBuch", 1906 Hymn #74, page 57 Ed. Karl Brauer. slightly altered.</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6.May we in faith its tidings learn
Nor thanklessly its blessings spurn;
May we in faith its truth confess
And praise the Lord our Righteousness!</miscellaneous-field>
    </miscellaneous>
  </identification>
