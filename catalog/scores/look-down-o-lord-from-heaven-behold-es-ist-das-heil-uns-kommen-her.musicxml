<!DOCTYPE score-partwise PUBLIC "-//Recordare//DTD MusicXML 3.0 Partwise//EN" "http://www.musicxml.org/dtds/partwise.dtd">
<score-partwise>
  <work>
    <work-number>(also known as O God, from Heaven Look Down or O God, Look Down from Heaven and See)</work-number>
    <work-title>Look Down, O Lord, From Heaven Behold</work-title>
  </work>
  <identification>
    <creator type="composer">Words: Martin Luther, 1524. Translated by Frances Elizabeth Cox, 1864. Music: 'Es ist das Heil uns Kommen Her'
traditional German circa 1400 from Etlich Christlich Lider, Wittenberg, 1524.  Setting: Karl August Haupt, 1869.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2009 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: "The Hymns of Martin Luther" by Bacon, 1883.</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6. Thy truth thou wilt preserve, O Lord, From this vile generation;
Make us to lean upon thy word, With calm anticipation.
The wicked walk on every side When, 'mid thy flock, the vile abide In pow'r and exaltation.</miscellaneous-field>
    </miscellaneous>
  </identification>
