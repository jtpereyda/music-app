# Server-only base URL of the render service, without a trailing slash.
# Next.js proxies fixed-catalog SVG/PDF requests through its same-origin route.
# Vercel Services injects this through a private service binding.
RENDER_API_URL=http://localhost:8000

# Keep static for builds and offline development. Use neon only after applying
# database/migrations and the catalog seed.
CATALOG_SOURCE=static

# Canonical production origin used in sitemap and social metadata.
# SITE_URL=https://www.example.com

# Keep false until the publication-reviewed launch catalog is ready.
SITE_INDEXABLE=false

# Private /admin dashboard. Create a Google OAuth web client with these
# authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://transposify.com/api/auth/callback/google
# Generate AUTH_SECRET with: npx auth secret
# AUTH_SECRET=replace-with-a-random-secret
# AUTH_GOOGLE_ID=replace-with-google-client-id
# AUTH_GOOGLE_SECRET=replace-with-google-client-secret

# Server-only pooled Neon connection string. Never prefix this with NEXT_PUBLIC.
# DATABASE_URL=postgresql://...
