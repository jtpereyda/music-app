<score-partwise>
  <work>
    <work-number>(also known as Abide with Us, Lord Jesus or Abide Among Us with Thy Grace or
Abide with Us, Our Savior or Come, Abide with Thy Grace, in Our Hearts or O Savior, Go Beside us)</work-number>
    <work-title>Abide, O Dearest Jesus</work-title>
  </work>
  <identification>
    <creator type="composer">Words: Joshua Stegmann, 1628.  Translated by August Crull circa 1892.
Music: 'Christus der ist mein Leben' Melchior Vulpius, 1609.
Setting: "Mehrstimmiges ChoralBuch", 1906.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2013 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: "Mehrstimmiges ChoralBuch", 1906 Hymn #32, page 23 Ed. Karl Brauer.</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6. Abide, O faithful Savior, Among us with Thy love;
Grant steadfastness, and help us To reach our home above.</miscellaneous-field>
    </miscellaneous>
  </identification>
