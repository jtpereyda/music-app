<score-partwise>
  <work>
    <work-title>Nearer, My God, To Thee</work-title>
  </work>
  <identification>
    <creator type="composer">Words: st. 1-2 by Sarah F. Adams, 1841. st. 3-5 by Hervey D. Ganse (1822-1891).
st. 6 by Edward H. Bickersteth, Jr. (1825-1906).
Music: 'Bethany (Mason)' Lowell Mason, 1856.  Setting: Lowell Mason, 1859.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2008 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: "The Sabbath Hymn and Tune Book", 1859 page 244. Ed. Lowell Mason.</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6.There in my Father's home, safe and at rest,
There in my Savior's love, perfectly blest; Age
after age to be, nearer my God to Thee.</miscellaneous-field>
    </miscellaneous>
  </identification>
