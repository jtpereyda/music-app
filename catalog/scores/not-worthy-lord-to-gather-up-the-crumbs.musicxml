<score-partwise>
  <work>
    <work-title>Not Worthy, Lord, to Gather Up the Crumbs</work-title>
  </work>
  <identification>
    <creator type="composer">Words: Edward Henry Bickersteth, 1872.  Music: 'Eventide' William H. Monk, 1861.  Setting: William H. Monk, 1861.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2012 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: Hymns Ancient and Modern, 1869 hymn 14. (ed. William H. Monk)  Lyrics from "The chamber of peace, and other religious poems" edited by Anson D. F. Randolph, 1874 page 172</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6.My praise can only breathe itself in prayer,
My prayer can only lose itself in Thee;
Dwell Thou forever in my heart, and there,
Lord, let me sup with Thee; sup Thou with me.</miscellaneous-field>
    </miscellaneous>
  </identification>
