<score-partwise>
  <work>
    <work-title>Within the Father's House</work-title>
  </work>
  <identification>
    <creator type="composer">Words: James Russell Woodford, 1863.
Music: 'Franconia' Johann Balthasar König, 1738.  Setting: William Henry Havergal, 1847.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2013 Revision.</creator>
    <encoding>
      <encoder>abc2xml version 268</encoder>
      <software>https://wim.vree.org/svgParse/abc2xml.html</software>
      <encoding-date>2026-07-21</encoding-date>
    </encoding>
    <source>Music source: "The Presbyterian Hymnal", 1874 hymn 118.  Lyrics source same v.1-6.</source>
    <miscellaneous>
      <miscellaneous-field name="lyrics">6. Till from our darkened sight
The cloud shall pass away,
And on the cleansèd soul shall burst
The everlasting day.

7. Till we behold Thy face,
And know, as we are known,
Thee, Father, Son, and Holy Ghost,
Co-equal Three in One.</miscellaneous-field>
    </miscellaneous>
  </identification>
