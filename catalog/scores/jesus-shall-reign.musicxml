  <work>
    <work-title>Jesus Shall Reign</work-title>
  </work>
  <identification>
    <creator type="composer">Words: Isaac Watts, 1719.
Music: 'Duke Street' John Hatton, 1793.  Setting: "Christian Hymns", 1908.
copyright: public domain.  This score is a part of the Open Hymnal Project, 2011 Revision.</creator>
