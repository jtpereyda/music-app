    <miscellaneous>
      <miscellaneous-field name="lyrics">6.Let every creature rise and bring
Peculiar honors to our King,
Angels descend with songs again,
And earth repeat the loud Amen.</miscellaneous-field>
    </miscellaneous>
  </identification>
